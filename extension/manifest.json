{
  "manifest_version": 3,
  "name": "DamKoi — Bangladesh Shopping Intelligence",
  "description": "Real price history and fake-discount detection for Daraz, Cartup, Rokomari, Pickaboo, Chaldal, and Othoba.",
  "version": "2.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.daraz.com.bd/products/*",
        "*://www.daraz.com.bd/*-i*-s*.html",
        "*://www.daraz.com.bd/i*-s*.html",
        "*://www.cartup.com.bd/products/*",
        "*://cartup.com.bd/products/*",
        "*://www.rokomari.com/book/*",
        "*://rokomari.com/book/*",
        "*://www.pickaboo.com/product/*",
        "*://pickaboo.com/product/*",
        "*://chaldal.com/*/*",
        "*://www.chaldal.com/*/*",
        "*://www.othoba.com/product/*",
        "*://othoba.com/product/*"
      ],
      "js": ["content.bundle.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.daraz.com.bd/checkout/*",
        "*://www.daraz.com.bd/cart/*"
      ],
      "js": ["cart_detector.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.bundle.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://api.damkoi.com/*",
    "https://www.daraz.com.bd/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "https://www.cartup.com.bd/*",
    "https://www.rokomari.com/*",
    "https://www.pickaboo.com/*",
    "https://chaldal.com/*",
    "https://www.chaldal.com/*",
    "https://www.othoba.com/*",
    "https://othoba.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/dk_logo.svg",
        "icons/icon16.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": [
        "*://*.daraz.com.bd/*",
        "*://*.cartup.com.bd/*",
        "*://*.rokomari.com/*",
        "*://*.pickaboo.com/*",
        "*://*.chaldal.com/*",
        "*://*.othoba.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://api.damkoi.com"
  }
}
