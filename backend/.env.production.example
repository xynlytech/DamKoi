# ============================================================
# DamKoi Backend — Production Environment Variables
# Copy this file to .env on your server and fill in the values.
# NEVER commit the real .env file to version control.
# ============================================================

# ── App Mode ─────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
API_BASE_URL=https://api.damkoi.com

# ── Frontend & CORS ───────────────────────────────────────────
FRONTEND_URL=https://damkoi.com

# CORS_ORIGINS: JSON array of allowed origins.
# Must include your frontend domain and the chrome-extension:// origin.
# Get the extension ID from chrome://extensions after publishing.
CORS_ORIGINS=["https://damkoi.com","https://www.damkoi.com"]

# Your published Chrome extension's stable ID (from Chrome Web Store)
# Automatically appended to CORS origins as chrome-extension://{ID}
ALLOWED_EXTENSION_ID=your_chrome_extension_id_here

# Your production API domain (auto-added to CORS if not already in CORS_ORIGINS)
PRODUCTION_DOMAIN=https://api.damkoi.com

# ── Database (Supabase PostgreSQL) ────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → Database
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Redis (Upstash) ───────────────────────────────────────────
# Get from: https://upstash.com → Redis → Connect → .env
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379

# ── Supabase Auth ─────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── Email (Resend) ────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_production_api_key
EMAIL_FROM=alerts@damkoi.com

# ── Error Monitoring (Sentry) ─────────────────────────────────
# Get from: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-production-bot-token
TELEGRAM_CHAT_ID=your-channel-id

# ── Rate Limiting ─────────────────────────────────────────────
# Tighter limits for production to prevent API abuse
RATE_LIMIT_ANONYMOUS=20/minute
RATE_LIMIT_AUTHENTICATED=100/minute
RATE_LIMIT_EXTENSION=60/minute

# ── Scraper Config ────────────────────────────────────────────
SCRAPE_DELAY_MIN=3.0
SCRAPE_DELAY_MAX=7.0
SCRAPE_MAX_RETRIES=3
SCRAPE_RETRY_DELAY=1800

# ============================================================
# Deployment Checklist:
# 1. ✅ Set APP_ENV=production and APP_DEBUG=false
# 2. ✅ Fill in DATABASE_URL with your Supabase credentials
# 3. ✅ Set ALLOWED_EXTENSION_ID after publishing to Chrome Web Store
# 4. ✅ Set CORS_ORIGINS to your live domain(s) only
# 5. ✅ Set RESEND_API_KEY (verify your domain in Resend first)
# 6. ✅ Set SENTRY_DSN for error tracking
# 7. ✅ Run: alembic upgrade head (handled automatically by Dockerfile CMD)
# ============================================================
