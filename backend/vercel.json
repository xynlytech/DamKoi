{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "requirementsFile": "requirements-vercel.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  },
  "crons": [
    {
      "path": "/cron/ping",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/cron/alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/cron/coupons",
      "schedule": "15 */2 * * *"
    },
    {
      "path": "/cron/matching",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/cron/daily-digest",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/cron/backfill",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/cron/cleanup",
      "schedule": "0 23 * * *"
    }
  ]
}
